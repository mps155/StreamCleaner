{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log_sistema_.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ScannerSettings": {
    "RunIntervalMinutes": 5,
    "RemoveOlderFiles": false,
    "MoveToBackupFolder": "C:\\Users\\michel.santos\\BackupDuplicados",
    "TargetDirectories": [
      "C:\\Users\\michel.santos\\Downloads",
      "C:\\Users\\michel.santos\\Documents"
    ],
    "AllowedExtensions": [
      ".jpg",
      ".png",
      ".mp4",
      ".pdf"
    ],
    "OutputPath": "C:\\LogsDuplicados"
  }
}
